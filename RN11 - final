void stepMotorChunk(int steps, SystemMode expectedMode) {
  for (int i = 0; i < steps; i++) {
    if (currentMode != expectedMode) return; 
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(motorSpeed);
    digitalWrite(stepPin, LOW);
    delayMicroseconds(motorSpeed);
    if (i % 20 == 0) taskYIELD(); 
  }
}

void runComboSequence() {
  digitalWrite(dirPin, HIGH);
  while(digitalRead(BUTTON_PIN_1) == HIGH && currentMode == MODE_COMBO_SEQUENCE) {
    stepMotorChunk(20, MODE_COMBO_SEQUENCE);
  }
  if (currentMode != MODE_COMBO_SEQUENCE) return; 
  
  uint32_t waitTime = 30000; // UPDATED FALLBACK
  float deadband = 0.03;     // UPDATED FALLBACK
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    waitTime = floatWaitTimeMs;
    deadband = depthToleranceCm / 100.0;
    xSemaphoreGive(configLock);
  }
  
  uint32_t startTime = millis();
  while ((millis() - startTime) < waitTime) {
    if (currentMode != MODE_COMBO_SEQUENCE) return; 
    vTaskDelay(pdMS_TO_TICKS(100)); 
  }
  if (currentMode != MODE_COMBO_SEQUENCE) return; 

  float target = 0.0;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    target = targetDepthSetpoint;
    xSemaphoreGive(modeLock);
  }

  bool targetReached = false;
  uint32_t holdStartTime = 0;

  while (currentMode == MODE_COMBO_SEQUENCE) {
    float currentDepthCopy = 0.0;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentDepthCopy = currentRelativeDepth;
      xSemaphoreGive(dataLock);
    }

    if (currentDepthCopy > (target + deadband)) {
      digitalWrite(dirPin, HIGH); 
      if (digitalRead(BUTTON_PIN_1) == HIGH) stepMotorChunk(20, MODE_COMBO_SEQUENCE);
      else vTaskDelay(pdMS_TO_TICKS(50)); 
    } 
    else if (currentDepthCopy < (target - deadband)) {
      digitalWrite(dirPin, LOW); 
      if (digitalRead(BUTTON_PIN_2) == HIGH) stepMotorChunk(20, MODE_COMBO_SEQUENCE);
      else vTaskDelay(pdMS_TO_TICKS(50)); 
    } 
    else {
      if (!targetReached) {
        targetReached = true;
        holdStartTime = millis(); 
      }
      vTaskDelay(pdMS_TO_TICKS(50));
    }

    if (targetReached) {
      if (millis() - holdStartTime >= waitTime) {
        break; 
      }
    }
  }

  if (currentMode == MODE_COMBO_SEQUENCE) {
    digitalWrite(dirPin, LOW); 
    while (digitalRead(BUTTON_PIN_2) == HIGH && currentMode == MODE_COMBO_SEQUENCE) {
      stepMotorChunk(20, MODE_COMBO_SEQUENCE);
    }
  }

  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    if (currentMode == MODE_COMBO_SEQUENCE) currentMode = MODE_IDLE;
    xSemaphoreGive(modeLock);
  }
}

void runStepperSequence() {
  digitalWrite(dirPin, HIGH);
  while(digitalRead(BUTTON_PIN_1) == HIGH && currentMode == MODE_SEQUENCE) stepMotorChunk(20, MODE_SEQUENCE);
  if (currentMode != MODE_SEQUENCE) return; 
  
  uint32_t waitTime = 30000; // UPDATED FALLBACK
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    waitTime = floatWaitTimeMs;
    xSemaphoreGive(configLock);
  }
  
  uint32_t startTime = millis();
  while ((millis() - startTime) < waitTime) {
    if (currentMode != MODE_SEQUENCE) return; 
    vTaskDelay(pdMS_TO_TICKS(100)); 
  }
  
  if (currentMode != MODE_SEQUENCE) return; 
  digitalWrite(dirPin, LOW);
  while(digitalRead(BUTTON_PIN_2) == HIGH && currentMode == MODE_SEQUENCE) stepMotorChunk(20, MODE_SEQUENCE);
  
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    if (currentMode == MODE_SEQUENCE) currentMode = MODE_IDLE;
    xSemaphoreGive(modeLock);
  }
}

void runTimedDownSequence() {
  uint32_t durationMs = 0;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    durationMs = timedDownDurationMs;
    xSemaphoreGive(modeLock);
  }

  digitalWrite(dirPin, HIGH); 
  uint32_t startTime = millis();

  while ((millis() - startTime) < durationMs && digitalRead(BUTTON_PIN_1) == HIGH && currentMode == MODE_TIMED_DOWN) {
    stepMotorChunk(20, MODE_TIMED_DOWN);
  }

  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    if (currentMode == MODE_TIMED_DOWN) currentMode = MODE_HOLD_DEPTH;
    xSemaphoreGive(modeLock);
  }
}

void runHoldDepthSequence() {
  uint32_t holdDurationMs = 30000; // UPDATED FALLBACK
  float deadband = 0.03;           // UPDATED FALLBACK

  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    holdDurationMs = floatWaitTimeMs;
    deadband = depthToleranceCm / 100.0; 
    xSemaphoreGive(configLock);
  }

  float targetDepth = 0.0;
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    targetDepth = currentRelativeDepth;
    xSemaphoreGive(dataLock);
  }

  uint32_t startTime = millis();

  while ((millis() - startTime) < holdDurationMs && currentMode == MODE_HOLD_DEPTH) {
    
    float currentDepthCopy = 0.0;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentDepthCopy = currentRelativeDepth;
      xSemaphoreGive(dataLock);
    }

    if (currentDepthCopy > (targetDepth + deadband)) {
      digitalWrite(dirPin, HIGH); 
      if (digitalRead(BUTTON_PIN_1) == HIGH) stepMotorChunk(20, MODE_HOLD_DEPTH);
      else vTaskDelay(pdMS_TO_TICKS(50)); 
    } 
    else if (currentDepthCopy < (targetDepth - deadband)) {
      digitalWrite(dirPin, LOW); 
      if (digitalRead(BUTTON_PIN_2) == HIGH) stepMotorChunk(20, MODE_HOLD_DEPTH);
      else vTaskDelay(pdMS_TO_TICKS(50)); 
    } 
    else {
      vTaskDelay(pdMS_TO_TICKS(50));
    }
  }

  bool shouldSurface = false;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    shouldSurface = returnToSurfaceAfterHold;
    xSemaphoreGive(modeLock);
  }

  if (shouldSurface && currentMode == MODE_HOLD_DEPTH) {
    digitalWrite(dirPin, LOW); 
    while (digitalRead(BUTTON_PIN_2) == HIGH && currentMode == MODE_HOLD_DEPTH) {
      stepMotorChunk(20, MODE_HOLD_DEPTH);
    }
  }

  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    if (currentMode == MODE_HOLD_DEPTH) currentMode = MODE_IDLE;
    xSemaphoreGive(modeLock);
  }
}

void runTargetDepthSequence() {
  uint32_t holdDurationMs = 30000; // UPDATED FALLBACK
  float deadband = 0.03;           // UPDATED FALLBACK
  
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    holdDurationMs = floatWaitTimeMs;
    deadband = depthToleranceCm / 100.0; 
    xSemaphoreGive(configLock);
  }

  float target = 0.0;
  bool shouldSurface = false;
  bool forever = false;
  
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    target = targetDepthSetpoint;
    shouldSurface = targetDepthReturn;
    forever = targetDepthForever;
    xSemaphoreGive(modeLock);
  }

  bool targetReached = false;
  uint32_t holdStartTime = 0;

  while (currentMode == MODE_TARGET_DEPTH) {
    
    float currentDepthCopy = 0.0;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentDepthCopy = currentRelativeDepth;
      xSemaphoreGive(dataLock);
    }

    if (currentDepthCopy > (target + deadband)) {
      digitalWrite(dirPin, HIGH); 
      if (digitalRead(BUTTON_PIN_1) == HIGH) stepMotorChunk(20, MODE_TARGET_DEPTH);
      else vTaskDelay(pdMS_TO_TICKS(50)); 
    } 
    else if (currentDepthCopy < (target - deadband)) {
      digitalWrite(dirPin, LOW); 
      if (digitalRead(BUTTON_PIN_2) == HIGH) stepMotorChunk(20, MODE_TARGET_DEPTH);
      else vTaskDelay(pdMS_TO_TICKS(50)); 
    } 
    else {
      if (!targetReached) {
        targetReached = true;
        holdStartTime = millis(); 
      }
      vTaskDelay(pdMS_TO_TICKS(50));
    }

    if (targetReached && !forever) {
      if (millis() - holdStartTime >= holdDurationMs) {
        break; 
      }
    }
  }

  if (shouldSurface && currentMode == MODE_TARGET_DEPTH) {
    digitalWrite(dirPin, LOW); 
    while (digitalRead(BUTTON_PIN_2) == HIGH && currentMode == MODE_TARGET_DEPTH) {
      stepMotorChunk(20, MODE_TARGET_DEPTH);
    }
  }

  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    if (currentMode == MODE_TARGET_DEPTH) currentMode = MODE_IDLE;
    xSemaphoreGive(modeLock);
  }
}

void motorTask(void *parameter) {
  while(1) {
    SystemMode currentModeCopy;
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentModeCopy = currentMode;
      xSemaphoreGive(modeLock);
    }
    
    if (currentModeCopy == MODE_SEQUENCE) runStepperSequence();
    else if (currentModeCopy == MODE_TIMED_DOWN) runTimedDownSequence();
    else if (currentModeCopy == MODE_HOLD_DEPTH) runHoldDepthSequence();
    else if (currentModeCopy == MODE_TARGET_DEPTH) runTargetDepthSequence();
    else if (currentModeCopy == MODE_COMBO_SEQUENCE) runComboSequence(); 
    else vTaskDelay(pdMS_TO_TICKS(100)); 
  }
}

void setup() {
  Serial.begin(115200); 
  delay(1000);
  
  Wire.begin(CUSTOM_SDA_PIN, CUSTOM_SCL_PIN);
  
  if (sensor.init()) {
    sensorActive = true;
    sensor.setFluidDensity(997); 
    sensor.read();
    surfaceDepthOffset = sensor.depth(); 
    Serial.println("Sensor Initialized.");
  } else {
    Serial.println("Sensor FAILED - Continuing to start Wi-Fi.");
    sensorActive = false;
  }
  
  pinMode(dirPin, OUTPUT);
  pinMode(stepPin, OUTPUT);
  pinMode(BUTTON_PIN_1, INPUT_PULLUP);
  pinMode(BUTTON_PIN_2, INPUT_PULLUP); 
  
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);
  WiFi.setSleep(false);
  
  ArduinoOTA.begin();
  server.on("/data", handleData);
  server.on("/live", handleLive);
  server.on("/control", handleControl);
  server.on("/config", handleConfig);
  server.begin();
  
  dataLock = xSemaphoreCreateMutex();
  modeLock = xSemaphoreCreateMutex();
  configLock = xSemaphoreCreateMutex();
  
  randomSeed(analogRead(34)); 
  
  xTaskCreatePinnedToCore(sensorTask, "SensorTask", 4096, NULL, 2, &sensorTaskHandle, 0);
  xTaskCreatePinnedToCore(webTask, "WebTask", 4096, NULL, 1, &webTaskHandle, 0);
  xTaskCreatePinnedToCore(motorTask, "MotorTask", 4096, NULL, 3, &motorTaskHandle, 1);
}

void loop() {
  ArduinoOTA.handle(); 
  vTaskDelay(pdMS_TO_TICKS(1000));
}
