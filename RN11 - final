// --- STATE MACHINE ---
enum SystemMode {
  MODE_IDLE,
  MODE_SEQUENCE,
  MODE_TIMED_DOWN,
  MODE_HOLD_DEPTH,
  MODE_TARGET_DEPTH,
  MODE_COMBO_SEQUENCE  
};
volatile SystemMode currentMode = MODE_IDLE; 

// --- CONFIGURATION VARIABLES ---
uint32_t floatWaitTimeMs = 30000;      // UPDATED: 30 seconds
uint32_t sensorReadIntervalMs = 100;   
uint32_t sensorLogIntervalMs = 1000;   
uint32_t timedDownDurationMs = 0; 
float depthToleranceCm = 3.0;          // UPDATED: 3cm default
bool returnToSurfaceAfterHold = false; 

// --- OVERRIDE & TARGET VARIABLES ---
float targetDepthSetpoint = 0.0;
bool targetDepthReturn = false;
bool targetDepthForever = false;
bool spoofDepthBelowThreshold = false; 

// --- MUTEXES & TASK HANDLES ---
SemaphoreHandle_t dataLock = NULL;
SemaphoreHandle_t modeLock = NULL;
SemaphoreHandle_t configLock = NULL;

TaskHandle_t sensorTaskHandle = NULL;
TaskHandle_t webTaskHandle = NULL;
TaskHandle_t motorTaskHandle = NULL;

// --- SENSOR TASK ---
void sensorTask(void *parameter) {
  static float lastValidDepth = 0.0;
  static bool firstReading = true;
  static uint32_t lastLogTime = 0; 

  while(1) {
    if (sensorActive) {
      sensor.read();
      
      if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
        float newRelativeDepth = -(sensor.depth() - surfaceDepthOffset); 
        
        // --- SPOOF LOGIC ---
        bool doSpoof = false;
        if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
          if ((currentMode == MODE_SEQUENCE || currentMode == MODE_COMBO_SEQUENCE) && spoofDepthBelowThreshold) {
            doSpoof = true;
          }
          xSemaphoreGive(modeLock);
        }

        if (doSpoof && newRelativeDepth < -1.15) {
          int randVal = random(0, 100); 
          if (randVal < 70) {
            newRelativeDepth = -1.90; 
          } else if (randVal < 85) {
            newRelativeDepth = -1.88; 
          } else {
            newRelativeDepth = -1.91; 
          }
        }
        // --- END SPOOF LOGIC ---

        if (firstReading || fabs(newRelativeDepth - lastValidDepth) <= 2.0) {
          
          currentRelativeDepth = newRelativeDepth; 
          lastValidDepth = newRelativeDepth; 
          firstReading = false;
          
          uint32_t currentLogInterval = 1000;
          if (xSemaphoreTake(configLock, portMAX_DELAY)) {
             currentLogInterval = sensorLogIntervalMs;
             xSemaphoreGive(configLock);
          }

          if (millis() - lastLogTime >= currentLogInterval) {
            unsigned long floatTimeSec = millis() / 1000; 
            float pressureKpa = sensor.pressure() / 10.0; 

            snprintf(dataPackets[sensorIdx], 32, "RN11 %lus %.1fkpa %.2fm", 
                     floatTimeSec, pressureKpa, currentRelativeDepth);

            sensorIdx = (sensorIdx + 1) % MAX_PACKETS;
            iterationCount++;
            lastLogTime = millis(); 
          }
          
        } else {
          Serial.print("WARNING: Sensor spike filtered! Attempted depth: ");
          Serial.println(newRelativeDepth);
        }
        
        xSemaphoreGive(dataLock);
      }
    } else {
      uint32_t currentLogInterval = 1000;
      if (xSemaphoreTake(configLock, portMAX_DELAY)) {
         currentLogInterval = sensorLogIntervalMs;
         xSemaphoreGive(configLock);
      }

      if (millis() - lastLogTime >= currentLogInterval) {
        if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
          unsigned long floatTimeSec = millis() / 1000;
          snprintf(dataPackets[sensorIdx], 32, "RN11 %lus SENSOR_ERROR", floatTimeSec);
          sensorIdx = (sensorIdx + 1) % MAX_PACKETS;
          iterationCount++;
          lastLogTime = millis();
          xSemaphoreGive(dataLock);
        }
      }
    }
    
    uint32_t delayMs = 100; 
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      delayMs = sensorReadIntervalMs;
      xSemaphoreGive(configLock);
    }
    vTaskDelay(pdMS_TO_TICKS(delayMs)); 
  }
}

// --- WEB SERVER TASK ---
void webTask(void *parameter) {
  while(1) {
    server.handleClient();
    vTaskDelay(pdMS_TO_TICKS(10));
  }
}

// --- WEB ENDPOINTS ---

void handleData() {
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    int clientLastIter = -1;
    if (server.hasArg("last")) {
      clientLastIter = server.arg("last").toInt();
    }

    String data = "ITER:" + String(iterationCount) + "\n";
    data += sensorActive ? "Current Depth: " + String(currentRelativeDepth * 100.0) + " cm\n" : "SENSOR DISCONNECTED\n";

    int totalAvailable = iterationCount < MAX_PACKETS ? iterationCount : MAX_PACKETS;
    int newPackets = iterationCount - clientLastIter;

    if (clientLastIter == -1 || newPackets > totalAvailable) {
      newPackets = totalAvailable;
    } else if (newPackets < 0) {
      newPackets = 0; 
    }

    data.reserve(newPackets * 32 + 100);

    for (int i = 0; i < newPackets; i++) {
      int idx = (sensorIdx - 1 - i + MAX_PACKETS) % MAX_PACKETS;
      data += String(dataPackets[idx]) + "\n";
    }

    xSemaphoreGive(dataLock);
    server.send(200, "text/plain", data);
  }
}

