// --- SENSOR VARIABLES ---
#define MAX_PACKETS 1200 
char dataPackets[MAX_PACKETS][32]; 
int sensorIdx = 0;
int iterationCount = 0;
float currentRelativeDepth = 0.0; 
float surfaceDepthOffset = 0.0;    

// --- MOTOR PINS & SETTINGS ---
const int dirPin  = 4;
const int stepPin = 16;
int motorSpeed = 2000;

// --- LIMIT SWITCHES ---
#define BUTTON_PIN_1 19    // Bottom / Sinking limit (Pulling water IN)
#define BUTTON_PIN_2 18    // Top / Floating limit (Pushing water OUT)

// --- POSITION TRACKING ---
long currentStepperPos = 0; 
long maxStepperPos = 30000; // Default safety bound, configurable in /config
volatile bool isHomed = false; // Must manually home to unlock dives

// --- STATE MACHINE ---
enum SystemMode {
  MODE_IDLE,
  MODE_HOMING,
  MODE_SEQUENCE,
  MODE_TIMED_DOWN,
  MODE_HOLD_DEPTH,
  MODE_TARGET_DEPTH_BANGBANG,
  MODE_TARGET_DEPTH_PID,
  MODE_COMBO_SEQUENCE  
};
volatile SystemMode currentMode = MODE_IDLE; // Starts IDLE, no moving on boot!

// --- CONFIGURATION VARIABLES ---
uint32_t floatWaitTimeMs = 30000;      
uint32_t sensorReadIntervalMs = 100;   
uint32_t sensorLogIntervalMs = 100;    
uint32_t timedDownDurationMs = 0; 
float depthToleranceCm = 3.0;          
bool returnToSurfaceAfterHold = true; 

// --- OVERRIDE, TARGET & PID VARIABLES ---
float targetDepthSetpoint = 0.0;
bool targetDepthReturn = true;
bool targetDepthForever = false;
bool spoofDepthBelowThreshold = false; 

// PID Tuning Parameters
float pidKp = 80.0;
float pidKi = 0.5;
float pidKd = 10.0;

// --- MUTEXES & TASK HANDLES ---
SemaphoreHandle_t dataLock = NULL;
SemaphoreHandle_t modeLock = NULL;
SemaphoreHandle_t configLock = NULL;

TaskHandle_t sensorTaskHandle = NULL;
TaskHandle_t webTaskHandle = NULL;
TaskHandle_t motorTaskHandle = NULL;

// --- STEPPER HELPER FUNCTION (Optimized for cooling) ---
bool singleStep(bool dirHigh) {
  if (dirHigh) { 
    if (digitalRead(BUTTON_PIN_1) == LOW) return false; 
    digitalWrite(dirPin, HIGH);
  } else { 
    if (digitalRead(BUTTON_PIN_2) == LOW) return false; 
    digitalWrite(dirPin, LOW);
  }
  
  // Send a tiny, fast pulse to trigger the step (no heavy blocking)
  digitalWrite(stepPin, HIGH);
  delayMicroseconds(10); 
  digitalWrite(stepPin, LOW);
  
  // Use FreeRTOS to handle the motor speed delay. 
  // This puts the CPU to sleep, drastically cooling down the ESP32.
  int delayMs = motorSpeed / 1000; 
  if (delayMs > 0) {
    vTaskDelay(pdMS_TO_TICKS(delayMs)); 
  } else {
    delayMicroseconds(motorSpeed); // Fallback if speed < 1000us
  }
  
  if (dirHigh) currentStepperPos++;
  else currentStepperPos--;
  
  return true;
}

// --- SENSOR TASK ---
void sensorTask(void *parameter) {
  static float lastValidDepth = 0.0;
  static bool firstReading = true;
  static uint32_t lastLogTime = 0; 

  while(1) {
    if (sensorActive) {
      sensor.read();
      if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
        float newRelativeDepth = -(sensor.depth() - surfaceDepthOffset); 
        
        if (firstReading || fabs(newRelativeDepth - lastValidDepth) <= 2.0) {
          currentRelativeDepth = newRelativeDepth; 
          lastValidDepth = newRelativeDepth; 
          firstReading = false;
          
          uint32_t currentLogInterval = 100;
          if (xSemaphoreTake(configLock, portMAX_DELAY)) {
             currentLogInterval = sensorLogIntervalMs;
             xSemaphoreGive(configLock);
          }

          if (millis() - lastLogTime >= currentLogInterval) {
            unsigned long floatTimeSec = millis() / 1000; 
            float pressureKpa = sensor.pressure() / 10.0; 

            snprintf(dataPackets[sensorIdx], 32, "RN10 %lus %.3fkpa %.2fm", 
                     floatTimeSec, pressureKpa, currentRelativeDepth);

            sensorIdx = (sensorIdx + 1) % MAX_PACKETS;
            if(iterationCount < MAX_PACKETS) iterationCount++;
            lastLogTime = millis(); 
          }
        }
        xSemaphoreGive(dataLock);
      }
    }
    
    uint32_t delayMs = 100; 
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      delayMs = sensorReadIntervalMs;
      xSemaphoreGive(configLock);
    }
    vTaskDelay(pdMS_TO_TICKS(delayMs)); 
  }
}

// --- WEB SERVER TASK ---
void webTask(void *parameter) {
  while(1) {
    server.handleClient();
    vTaskDelay(pdMS_TO_TICKS(10));
  }
}

// --- WEB ENDPOINTS ---
void handleData() {
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    String data = "ITER:" + String(iterationCount) + "\n";
    data += sensorActive ? "Current Depth: " + String(currentRelativeDepth * 100.0) + " cm\n" : "SENSOR DISCONNECTED\n";

    int totalAvailable = iterationCount < MAX_PACKETS ? iterationCount : MAX_PACKETS;
    data.reserve(totalAvailable * 32 + 100);

    for (int i = 0; i < totalAvailable; i++) {
      int idx = (sensorIdx - 1 - i + MAX_PACKETS) % MAX_PACKETS;
      data += String(dataPackets[idx]) + "\n";
    }

    xSemaphoreGive(dataLock);
    server.send(200, "text/plain", data);
  }
}

