void handleConfig() {
  if (server.method() == HTTP_POST || server.args() > 0) {
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      if (server.hasArg("waitTime") && server.arg("waitTime") != "") floatWaitTimeMs = server.arg("waitTime").toInt();
      if (server.hasArg("maxSteps") && server.arg("maxSteps") != "") maxStepperPos = server.arg("maxSteps").toInt();
      if (server.hasArg("tolerance") && server.arg("tolerance") != "") depthToleranceCm = server.arg("tolerance").toFloat(); 
      xSemaphoreGive(configLock);
    }
    server.sendHeader("Location", "/config");
    server.send(303);
    return;
  }

  uint32_t currWait = 0, currMaxSteps = 0;
  float currTolerance = 0.0;
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    currWait = floatWaitTimeMs;
    currMaxSteps = maxStepperPos;
    currTolerance = depthToleranceCm;
    xSemaphoreGive(configLock);
  }

  String html = "<html><head><meta name='viewport' content='width=device-width, initial-scale=1'>";
  html += "<style>body{font-family:Arial;} input, button{padding:12px; margin:5px 0 15px 0; font-size:16px; width:90%; max-width:400px; border-radius: 5px; border: 1px solid #ccc;}</style></head><body>";
  html += "<h2>Float Configuration</h2><form action='/config' method='POST'>";
  
  html += "<label>Hold Time (ms): <strong>" + String(currWait) + " ms</strong></label><br>";
  html += "<input type='number' name='waitTime'><br>";
  
  html += "<label>Max Stepper Bounds: <strong>" + String(currMaxSteps) + " steps</strong></label><br>";
  html += "<input type='number' name='maxSteps'><br>";

  html += "<label>Target Deadband (cm): <strong>" + String(currTolerance, 1) + " cm</strong></label><br>";
  html += "<input type='number' step='0.1' name='tolerance'><br>";

  html += "<button type='submit' style='background-color:#4CAF50; color:white; font-weight:bold;'>Save</button>";
  html += "</form><hr><button style='background-color:#ddd;' onclick=\"location.href='/control'\">Back to Control</button></body></html>";
  server.send(200, "text/html", html);
}

// --- MOTOR BEHAVIORS ---

void surfaceEmergency() {
  while(digitalRead(BUTTON_PIN_2) == HIGH && currentMode != MODE_HOMING) {
    singleStep(false);
    // Watchdog fix: feed the timer occasionally during the long blocking run
    if(currentStepperPos % 10 == 0) vTaskDelay(pdMS_TO_TICKS(1)); 
  }
}

void runPidSequence() {
  uint32_t holdDurationMs = 30000; 
  float deadbandCm = 3.0;          
  long maxStepsLocal = 30000;
  
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    holdDurationMs = floatWaitTimeMs;
    deadbandCm = depthToleranceCm; 
    maxStepsLocal = maxStepperPos;
    xSemaphoreGive(configLock);
  }

  float targetDepthCm = 0.0;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) { targetDepthCm = targetDepthSetpoint * 100.0; xSemaphoreGive(modeLock); }

  bool targetReached = false;
  uint32_t holdStartTime = 0;
  uint32_t lastPidTime = millis();
  
  float integral = 0.0;
  float prevError = 0.0;

  while (currentMode == MODE_TARGET_DEPTH_PID) {
    if (digitalRead(BUTTON_PIN_1) == LOW) {
      surfaceEmergency();
      currentMode = MODE_IDLE;
      break;
    }

    float currentDepthCm = 0.0;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentDepthCm = currentRelativeDepth * 100.0;
      xSemaphoreGive(dataLock);
    }

    uint32_t now = millis();
    float dt = (now - lastPidTime) / 1000.0; 
    if (dt <= 0.0) dt = 0.01;
    lastPidTime = now;

    float error = currentDepthCm - targetDepthCm; 

    if (abs(error) < 15.0) {
      integral += (error * dt);
    } else {
      integral = 0; 
    }

    float derivative = (error - prevError) / dt;
    prevError = error;

    float output = (pidKp * error) + (pidKi * integral) + (pidKd * derivative);
    
    long targetPos = currentStepperPos + (long)output; 
    if (targetPos < 0) targetPos = 0;
    if (targetPos > maxStepsLocal) targetPos = maxStepsLocal;

    if (currentStepperPos < targetPos) {
      singleStep(true); 
    } else if (currentStepperPos > targetPos) {
      singleStep(false); 
    } else {
      vTaskDelay(pdMS_TO_TICKS(10)); 
    }

    if (abs(error) <= deadbandCm) {
      if (!targetReached) {
        targetReached = true;
        holdStartTime = millis(); 
      }
    } 

    if (targetReached && (millis() - holdStartTime >= holdDurationMs)) {
      break; 
    }
    
    // Watchdog fix: Ensure the CPU breathes inside the fast PID loop
    vTaskDelay(pdMS_TO_TICKS(1)); 
  }

  if (currentMode == MODE_TARGET_DEPTH_PID) {
    surfaceEmergency();
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) { currentMode = MODE_IDLE; xSemaphoreGive(modeLock); }
  }
}

void runBangBangSequence() {
  uint32_t holdDurationMs = 30000; 
  float deadband = 0.03;           
  
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    holdDurationMs = floatWaitTimeMs;
    deadband = depthToleranceCm / 100.0; 
    xSemaphoreGive(configLock);
  }

  float target = 0.0;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) { target = targetDepthSetpoint; xSemaphoreGive(modeLock); }

  bool targetReached = false;
  uint32_t holdStartTime = 0;

  while (currentMode == MODE_TARGET_DEPTH_BANGBANG) {
    if (digitalRead(BUTTON_PIN_1) == LOW) {
      surfaceEmergency();
      currentMode = MODE_IDLE;
      break;
    }

    float currentDepthCopy = 0.0;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) { currentDepthCopy = currentRelativeDepth; xSemaphoreGive(dataLock); }

    if (currentDepthCopy > (target + deadband)) {
      for(int i=0; i<20; i++) singleStep(true);
    } 
    else if (currentDepthCopy < (target - deadband)) {
      for(int i=0; i<20; i++) singleStep(false);
    } 
    else {
      if (!targetReached) {
        targetReached = true;
        holdStartTime = millis(); 
      }
      vTaskDelay(pdMS_TO_TICKS(50));
    }

    if (targetReached && (millis() - holdStartTime >= holdDurationMs)) break; 

    // Watchdog fix: Ensure the CPU breathes inside the fast bang-bang loop
    vTaskDelay(pdMS_TO_TICKS(1)); 
  }

  if (currentMode == MODE_TARGET_DEPTH_BANGBANG) {
    surfaceEmergency();
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) { currentMode = MODE_IDLE; xSemaphoreGive(modeLock); }
  }
}

void motorTask(void *parameter) {
  while(1) {
    SystemMode currentModeCopy;
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) { currentModeCopy = currentMode; xSemaphoreGive(modeLock); }
    
    if (currentModeCopy == MODE_HOMING) {
      while(digitalRead(BUTTON_PIN_2) == HIGH) { 
        singleStep(false);
        // Watchdog fix for manual homing sequence
        if (currentStepperPos % 10 == 0) vTaskDelay(pdMS_TO_TICKS(1)); 
      }
      currentStepperPos = 0; 
      isHomed = true;
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) { currentMode = MODE_IDLE; xSemaphoreGive(modeLock); }
    }
    else if (currentModeCopy == MODE_TARGET_DEPTH_BANGBANG) runBangBangSequence();
    else if (currentModeCopy == MODE_TARGET_DEPTH_PID) runPidSequence();
    else vTaskDelay(pdMS_TO_TICKS(100)); 
  }
}

void setup() {
  Serial.begin(115200); 
  delay(1000);
  
  Wire.begin(CUSTOM_SDA_PIN, CUSTOM_SCL_PIN);
  
  if (sensor.init()) {
    sensorActive = true;
    sensor.setFluidDensity(997); 
    sensor.read();
    surfaceDepthOffset = sensor.depth(); 
  }
  
  pinMode(dirPin, OUTPUT);
  pinMode(stepPin, OUTPUT);
  pinMode(BUTTON_PIN_1, INPUT_PULLUP);
  pinMode(BUTTON_PIN_2, INPUT_PULLUP); 
  
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);
  WiFi.setSleep(false);
  
  ArduinoOTA.begin();
  server.on("/data", handleData);
  server.on("/control", handleControl);
  server.on("/config", handleConfig);
  server.begin();
  
  dataLock = xSemaphoreCreateMutex();
  modeLock = xSemaphoreCreateMutex();
  configLock = xSemaphoreCreateMutex();
  
  xTaskCreatePinnedToCore(sensorTask, "SensorTask", 4096, NULL, 2, &sensorTaskHandle, 0);
  xTaskCreatePinnedToCore(webTask, "WebTask", 4096, NULL, 1, &webTaskHandle, 0);
  xTaskCreatePinnedToCore(motorTask, "MotorTask", 4096, NULL, 3, &motorTaskHandle, 1);
}

void loop() {
  ArduinoOTA.handle(); 
  vTaskDelay(pdMS_TO_TICKS(1000));
}
