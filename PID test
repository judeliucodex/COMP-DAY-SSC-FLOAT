        currentMode = MODE_IDLE;
      } else if (action == "home") {
        currentMode = MODE_HOMING;
        isHomed = false;
      } else if (action == "bangbang" && server.hasArg("depth")) {
        if (isHomed) { // Only allow if homed!
          targetDepthSetpoint = server.arg("depth").toFloat() / 100.0; 
          currentMode = MODE_TARGET_DEPTH_BANGBANG;
        }
      } else if (action == "pid" && server.hasArg("depth")) {
